[
  {"order": 1, "ar": "الرَّحْمَٰنُ", "tr": "Er-Rahmân", "en": "The Most Gracious", "meaning_tr": "Çok merhamet eden, tüm yaratılmışlara dünyada nimetler veren.", "meaning_en": "The Most Gracious, who bestows mercy upon all creation."},
  {"order": 2, "ar": "الرَّحِيمُ", "tr": "Er-Rahîm", "en": "The Most Merciful", "meaning_tr": "Ahirette müminlere özel merhamet eden.", "meaning_en": "The Most Merciful to believers in the Hereafter."},
  {"order": 3, "ar": "الْمَلِكُ", "tr": "El-Melik", "en": "The King", "meaning_tr": "Mülkün gerçek sahibi, her şeye hükmeden.", "meaning_en": "The Sovereign King of all dominion."},
  {"order": 4, "ar": "الْقُدُّوسُ", "tr": "El-Kuddûs", "en": "The Holy", "meaning_tr": "Her türlü eksiklikten uzak, tertemiz olan.", "meaning_en": "The Pure, free from all imperfection."},
  {"order": 5, "ar": "السَّلَامُ", "tr": "Es-Selâm", "en": "The Source of Peace", "meaning_tr": "Kullarını selamete eriştiren, esenlik veren.", "meaning_en": "The Source of Peace and safety."},
  {"order": 6, "ar": "الْمُؤْمِنُ", "tr": "El-Mü'min", "en": "The Granter of Security", "meaning_tr": "Güven veren, iman nurunu kalplere yerleştiren.", "meaning_en": "The Granter of security and faith."},
  {"order": 7, "ar": "الْمُهَيْمِنُ", "tr": "El-Muheymin", "en": "The Guardian", "meaning_tr": "Her şeyi gözeten, koruyan ve yöneten.", "meaning_en": "The Guardian over all things."},
  {"order": 8, "ar": "الْعَزِيزُ", "tr": "El-Azîz", "en": "The Almighty", "meaning_tr": "Üstün gelen, mağlup edilemeyen.", "meaning_en": "The Almighty, never overcome."},
  {"order": 9, "ar": "الْجَبَّارُ", "tr": "El-Cebbâr", "en": "The Compeller", "meaning_tr": "Dilediğini yaptıran, kırık gönülleri onaran.", "meaning_en": "The Compeller who mends broken hearts."},
  {"order": 10, "ar": "الْمُتَكَبِّرُ", "tr": "El-Mütekebbir", "en": "The Supreme", "meaning_tr": "Büyüklükte eşi olmayan, her şeyden yüce olan.", "meaning_en": "The Supreme above all creation."},
  {"order": 11, "ar": "الْخَالِقُ", "tr": "El-Hâlık", "en": "The Creator", "meaning_tr": "Her şeyi yoktan var eden.", "meaning_en": "The Creator of all from nothing."},
  {"order": 12, "ar": "الْبَارِئُ", "tr": "El-Bâri'", "en": "The Evolver", "meaning_tr": "Yaratıkları birbirinden ayrı ve kusursuz biçimde var eden.", "meaning_en": "The Maker who forms creation flawlessly."},
  {"order": 13, "ar": "الْمُصَوِّرُ", "tr": "El-Musavvir", "en": "The Fashioner", "meaning_tr": "Her varlığa şekil ve suret veren.", "meaning_en": "The Fashioner of forms and shapes."},
  {"order": 14, "ar": "الْغَفَّارُ", "tr": "El-Gaffâr", "en": "The Forgiving", "meaning_tr": "Günahları çokça bağışlayan.", "meaning_en": "The Oft-Forgiving of sins."},
  {"order": 15, "ar": "الْقَهَّارُ", "tr": "El-Kahhâr", "en": "The Subduer", "meaning_tr": "Her şeye galip gelen, dilediğini mutlak surette gerçekleştiren.", "meaning_en": "The Subduer who prevails over all."},
  {"order": 16, "ar": "الْوَهَّابُ", "tr": "El-Vehhâb", "en": "The Bestower", "meaning_tr": "Karşılıksız bol bol ihsan eden.", "meaning_en": "The Bestower of gifts without measure."},
  {"order": 17, "ar": "الرَّزَّاقُ", "tr": "Er-Rezzâk", "en": "The Provider", "meaning_tr": "Bütün canlıların rızkını veren.", "meaning_en": "The Provider of sustenance for all."},
  {"order": 18, "ar": "الْفَتَّاحُ", "tr": "El-Fettâh", "en": "The Opener", "meaning_tr": "Kapıları açan, darlıktan kurtaran.", "meaning_en": "The Opener of doors and relief."},
  {"order": 19, "ar": "الْعَلِيمُ", "tr": "El-Alîm", "en": "The All-Knowing", "meaning_tr": "Her şeyi en ince ayrıntısına kadar bilen.", "meaning_en": "The All-Knowing of every detail."},
  {"order": 20, "ar": "الْقَابِضُ", "tr": "El-Kâbid", "en": "The Withholder", "meaning_tr": "Rızkı daraltan, canları alan.", "meaning_en": "The Withholder who constricts at will."},
  {"order": 21, "ar": "الْبَاسِطُ", "tr": "El-Bâsit", "en": "The Expander", "meaning_tr": "Rızkı genişleten, kalplere ferahlık veren.", "meaning_en": "The Expander of provision and hearts."},
  {"order": 22, "ar": "الْخَافِضُ", "tr": "El-Hâfid", "en": "The Abaser", "meaning_tr": "Dilediğini alçaltan.", "meaning_en": "The Abaser of whom He wills."},
  {"order": 23, "ar": "الرَّافِعُ", "tr": "Er-Râfi'", "en": "The Exalter", "meaning_tr": "Dilediğini yükselten.", "meaning_en": "The Exalter of whom He wills."},
  {"order": 24, "ar": "الْمُعِزُّ", "tr": "El-Muizz", "en": "The Honorer", "meaning_tr": "Dilediğine izzet ve şeref veren.", "meaning_en": "The Honorer who grants dignity."},
  {"order": 25, "ar": "الْمُذِلُّ", "tr": "El-Müzill", "en": "The Humiliator", "meaning_tr": "Dilediğini zillete düşüren.", "meaning_en": "The Humiliator of whom He wills."},
  {"order": 26, "ar": "السَّمِيعُ", "tr": "Es-Semî'", "en": "The All-Hearing", "meaning_tr": "Her sesi, her duayı işiten.", "meaning_en": "The All-Hearing of every sound and prayer."},
  {"order": 27, "ar": "الْبَصِيرُ", "tr": "El-Basîr", "en": "The All-Seeing", "meaning_tr": "Her şeyi gören, hiçbir şey O'na gizli kalmayan.", "meaning_en": "The All-Seeing, nothing hidden from Him."},
  {"order": 28, "ar": "الْحَكَمُ", "tr": "El-Hakem", "en": "The Judge", "meaning_tr": "Hüküm veren, adaletle karar kılan.", "meaning_en": "The Judge who rules with justice."},
  {"order": 29, "ar": "الْعَدْلُ", "tr": "El-Adl", "en": "The Just", "meaning_tr": "Son derece adil olan.", "meaning_en": "The Absolutely Just."},
  {"order": 30, "ar": "اللَّطِيفُ", "tr": "El-Latîf", "en": "The Subtle", "meaning_tr": "Lütuf ve ihsanı bol, ince işleri bilen.", "meaning_en": "The Subtle in kindness and knowledge."},
  {"order": 31, "ar": "الْخَبِيرُ", "tr": "El-Habîr", "en": "The All-Aware", "meaning_tr": "Her şeyin iç yüzünden haberdar olan.", "meaning_en": "The All-Aware of inner realities."},
  {"order": 32, "ar": "الْحَلِيمُ", "tr": "El-Halîm", "en": "The Forbearing", "meaning_tr": "Cezalandırmada acele etmeyen, yumuşak huylu.", "meaning_en": "The Forbearing, not hasty in punishment."},
  {"order": 33, "ar": "الْعَظِيمُ", "tr": "El-Azîm", "en": "The Magnificent", "meaning_tr": "Zat ve sıfatlarında pek yüce olan.", "meaning_en": "The Magnificent in essence and attributes."},
  {"order": 34, "ar": "الْغَفُورُ", "tr": "El-Gafûr", "en": "The Forgiving", "meaning_tr": "Günahları örten ve bağışlayan.", "meaning_en": "The Forgiving who covers sins."},
  {"order": 35, "ar": "الشَّكُورُ", "tr": "Eş-Şekûr", "en": "The Appreciative", "meaning_tr": "Az amele çok sevap veren.", "meaning_en": "The Appreciative of small deeds."},
  {"order": 36, "ar": "الْعَلِيُّ", "tr": "El-Aliyy", "en": "The Most High", "meaning_tr": "Her şeyden yüce olan.", "meaning_en": "The Most High above all."},
  {"order": 37, "ar": "الْكَبِيرُ", "tr": "El-Kebîr", "en": "The Greatest", "meaning_tr": "Büyüklükte eşi benzeri olmayan.", "meaning_en": "The Greatest without equal."},
  {"order": 38, "ar": "الْحَفِيظُ", "tr": "El-Hafîz", "en": "The Preserver", "meaning_tr": "Her şeyi koruyan ve muhafaza eden.", "meaning_en": "The Preserver of all things."},
  {"order": 39, "ar": "الْمُقِيتُ", "tr": "El-Mukît", "en": "The Nourisher", "meaning_tr": "Her canlının gıdasını ve gücünü veren.", "meaning_en": "The Nourisher who sustains all life."},
  {"order": 40, "ar": "الْحَسِيبُ", "tr": "El-Hasîb", "en": "The Reckoner", "meaning_tr": "Hesaba çeken, kâfi gelen.", "meaning_en": "The Reckoner, sufficient for all."},
  {"order": 41, "ar": "الْجَلِيلُ", "tr": "El-Celîl", "en": "The Majestic", "meaning_tr": "Azamet ve celal sahibi.", "meaning_en": "The Majestic in glory."},
  {"order": 42, "ar": "الْكَرِيمُ", "tr": "El-Kerîm", "en": "The Generous", "meaning_tr": "Çok cömert ve ikramı bol olan.", "meaning_en": "The Generous in giving."},
  {"order": 43, "ar": "الرَّقِيبُ", "tr": "Er-Rakîb", "en": "The Watchful", "meaning_tr": "Her an gözetleyen.", "meaning_en": "The Ever-Watchful."},
  {"order": 44, "ar": "الْمُجِيبُ", "tr": "El-Mucîb", "en": "The Responsive", "meaning_tr": "Dualara cevap veren.", "meaning_en": "The Responsive to prayers."},
  {"order": 45, "ar": "الْوَاسِعُ", "tr": "El-Vâsi'", "en": "The All-Encompassing", "meaning_tr": "İlmi ve rahmeti her şeyi kuşatan.", "meaning_en": "Whose knowledge and mercy encompass all."},
  {"order": 46, "ar": "الْحَكِيمُ", "tr": "El-Hakîm", "en": "The Wise", "meaning_tr": "Her işi hikmetle yapan.", "meaning_en": "The Wise in all affairs."},
  {"order": 47, "ar": "الْوَدُودُ", "tr": "El-Vedûd", "en": "The Loving", "meaning_tr": "Kullarını seven ve sevilmeye layık olan.", "meaning_en": "The Loving and Beloved."},
  {"order": 48, "ar": "الْمَجِيدُ", "tr": "El-Mecîd", "en": "The Glorious", "meaning_tr": "Şanı yüce, keremi bol olan.", "meaning_en": "The Glorious in honor."},
  {"order": 49, "ar": "الْبَاعِثُ", "tr": "El-Bâ'is", "en": "The Resurrector", "meaning_tr": "Ölüleri dirilten.", "meaning_en": "The Resurrector of the dead."},
  {"order": 50, "ar": "الشَّهِيدُ", "tr": "Eş-Şehîd", "en": "The Witness", "meaning_tr": "Her şeye şahit olan.", "meaning_en": "The Witness over all things."},
  {"order": 51, "ar": "الْحَقُّ", "tr": "El-Hakk", "en": "The Truth", "meaning_tr": "Varlığı kesin olan, hak olan.", "meaning_en": "The Absolute Truth."},
  {"order": 52, "ar": "الْوَكِيلُ", "tr": "El-Vekîl", "en": "The Trustee", "meaning_tr": "İşleri üstlenen, güvenilen.", "meaning_en": "The Trustee upon whom to rely."},
  {"order": 53, "ar": "الْقَوِيُّ", "tr": "El-Kaviyy", "en": "The Strong", "meaning_tr": "Kudreti sonsuz güçlü olan.", "meaning_en": "The Strong in perfect power."},
  {"order": 54, "ar": "الْمَتِينُ", "tr": "El-Metîn", "en": "The Firm", "meaning_tr": "Kuvveti çok sağlam ve sarsılmaz.", "meaning_en": "The Firm, unshakable in strength."},
  {"order": 55, "ar": "الْوَلِيُّ", "tr": "El-Veliyy", "en": "The Protector", "meaning_tr": "Müminlerin dostu ve koruyucusu.", "meaning_en": "The Protecting Friend of believers."},
  {"order": 56, "ar": "الْحَمِيدُ", "tr": "El-Hamîd", "en": "The Praiseworthy", "meaning_tr": "Her türlü hamde layık olan.", "meaning_en": "The Praiseworthy in every way."},
  {"order": 57, "ar": "الْمُحْصِي", "tr": "El-Muhsî", "en": "The Accounter", "meaning_tr": "Her şeyin sayısını bilen.", "meaning_en": "The Accounter of all things."},
  {"order": 58, "ar": "الْمُبْدِئُ", "tr": "El-Mubdi'", "en": "The Originator", "meaning_tr": "İlk defa yaratan.", "meaning_en": "The Originator of creation."},
  {"order": 59, "ar": "الْمُعِيدُ", "tr": "El-Muîd", "en": "The Restorer", "meaning_tr": "Yaratıkları tekrar dirilten.", "meaning_en": "The Restorer who brings back to life."},
  {"order": 60, "ar": "الْمُحْيِي", "tr": "El-Muhyî", "en": "The Giver of Life", "meaning_tr": "Hayat veren.", "meaning_en": "The Giver of life."},
  {"order": 61, "ar": "الْمُمِيتُ", "tr": "El-Mumît", "en": "The Taker of Life", "meaning_tr": "Canları alan, ölümü yaratan.", "meaning_en": "The Taker of life."},
  {"order": 62, "ar": "الْحَيُّ", "tr": "El-Hayy", "en": "The Living", "meaning_tr": "Diri, ölümü olmayan.", "meaning_en": "The Ever-Living, free from death."},
  {"order": 63, "ar": "الْقَيُّومُ", "tr": "El-Kayyûm", "en": "The Self-Subsisting", "meaning_tr": "Her şey O'na muhtaç, O hiçbir şeye muhtaç değil.", "meaning_en": "The Self-Subsisting upon whom all depend."},
  {"order": 64, "ar": "الْوَاجِدُ", "tr": "El-Vâcid", "en": "The Perceiver", "meaning_tr": "Dilediğini bulan, hiçbir şeye muhtaç olmayan.", "meaning_en": "The Perceiver who lacks nothing."},
  {"order": 65, "ar": "الْمَاجِدُ", "tr": "El-Mâcid", "en": "The Noble", "meaning_tr": "Şeref ve yücelik sahibi.", "meaning_en": "The Noble in glory."},
  {"order": 66, "ar": "الْوَاحِدُ", "tr": "El-Vâhid", "en": "The One", "meaning_tr": "Bir ve tek olan.", "meaning_en": "The One, without partner."},
  {"order": 67, "ar": "الْأَحَدُ", "tr": "El-Ehad", "en": "The Unique", "meaning_tr": "Zatında, sıfatlarında ve işlerinde tek olan.", "meaning_en": "The Unique in essence and attributes."},
  {"order": 68, "ar": "الصَّمَدُ", "tr": "Es-Samed", "en": "The Eternal", "meaning_tr": "Her şey O'na muhtaç, O hiçbir şeye muhtaç değil.", "meaning_en": "The Eternal Refuge for all."},
  {"order": 69, "ar": "الْقَادِرُ", "tr": "El-Kādir", "en": "The Able", "meaning_tr": "Her şeye gücü yeten.", "meaning_en": "The Able to do all things."},
  {"order": 70, "ar": "الْمُقْتَدِرُ", "tr": "El-Muktedir", "en": "The Powerful", "meaning_tr": "Kudreti tam ve mutlak olan.", "meaning_en": "The Powerful with absolute might."},
  {"order": 71, "ar": "الْمُقَدِّمُ", "tr": "El-Mukaddim", "en": "The Expediter", "meaning_tr": "Dilediğini öne alan.", "meaning_en": "The Expediter who brings forward."},
  {"order": 72, "ar": "الْمُؤَخِّرُ", "tr": "El-Muahhir", "en": "The Delayer", "meaning_tr": "Dilediğini geriye bırakan.", "meaning_en": "The Delayer who puts back."},
  {"order": 73, "ar": "الْأَوَّلُ", "tr": "El-Evvel", "en": "The First", "meaning_tr": "Varlığının başlangıcı olmayan.", "meaning_en": "The First without beginning."},
  {"order": 74, "ar": "الْآخِرُ", "tr": "El-Âhir", "en": "The Last", "meaning_tr": "Varlığının sonu olmayan.", "meaning_en": "The Last without end."},
  {"order": 75, "ar": "الظَّاهِرُ", "tr": "Ez-Zâhir", "en": "The Manifest", "meaning_tr": "Varlığı açık ve her yerde hazır olan.", "meaning_en": "The Manifest in existence."},
  {"order": 76, "ar": "الْبَاطِنُ", "tr": "El-Bâtın", "en": "The Hidden", "meaning_tr": "Zatı akılların kavrayışının ötesinde olan.", "meaning_en": "The Hidden beyond perception."},
  {"order": 77, "ar": "الْوَالِي", "tr": "El-Vâlî", "en": "The Governor", "meaning_tr": "Mülkün tek yöneticisi.", "meaning_en": "The Sole Governor of creation."},
  {"order": 78, "ar": "الْمُتَعَالِي", "tr": "El-Muteâlî", "en": "The Exalted", "meaning_tr": "Her türlü eksiklikten uzak ve yüce olan.", "meaning_en": "The Exalted above all deficiency."},
  {"order": 79, "ar": "الْبَرُّ", "tr": "El-Berr", "en": "The Source of Good", "meaning_tr": "Kullarına iyilik ve ihsanı bol olan.", "meaning_en": "The Source of all good."},
  {"order": 80, "ar": "التَّوَّابُ", "tr": "Et-Tevvâb", "en": "The Acceptor of Repentance", "meaning_tr": "Tevbeleri kabul eden.", "meaning_en": "The Acceptor of repentance."},
  {"order": 81, "ar": "الْمُنْتَقِمُ", "tr": "El-Muntakim", "en": "The Avenger", "meaning_tr": "Zalimlerden intikam alan.", "meaning_en": "The Avenger against wrongdoers."},
  {"order": 82, "ar": "الْعَفُوُّ", "tr": "El-Afüvv", "en": "The Pardoner", "meaning_tr": "Affı bol olan.", "meaning_en": "The Pardoner of great forgiveness."},
  {"order": 83, "ar": "الرَّؤُوفُ", "tr": "Er-Raûf", "en": "The Compassionate", "meaning_tr": "Kullarına çok şefkatli ve merhametli.", "meaning_en": "The Most Compassionate."},
  {"order": 84, "ar": "مَالِكُ الْمُلْكِ", "tr": "Mâlikü'l-Mülk", "en": "Owner of Sovereignty", "meaning_tr": "Mülkün gerçek sahibi.", "meaning_en": "Owner of all sovereignty."},
  {"order": 85, "ar": "ذُو الْجَلَالِ وَالْإِكْرَامِ", "tr": "Zü'l-Celâli ve'l-İkrâm", "en": "Lord of Glory and Honor", "meaning_tr": "Celal ve ikram sahibi.", "meaning_en": "Lord of Majesty and Honor."},
  {"order": 86, "ar": "الْمُقْسِطُ", "tr": "El-Muksit", "en": "The Equitable", "meaning_tr": "Adaletle hükmeden.", "meaning_en": "The Equitable in judgment."},
  {"order": 87, "ar": "الْجَامِعُ", "tr": "El-Câmi'", "en": "The Gatherer", "meaning_tr": "Mahşerde insanları toplayan.", "meaning_en": "The Gatherer on Judgment Day."},
  {"order": 88, "ar": "الْغَنِيُّ", "tr": "El-Ganiyy", "en": "The Self-Sufficient", "meaning_tr": "Hiçbir şeye muhtaç olmayan.", "meaning_en": "The Self-Sufficient, free of need."},
  {"order": 89, "ar": "الْمُغْنِي", "tr": "El-Muğnî", "en": "The Enricher", "meaning_tr": "Dilediğini zengin kılan.", "meaning_en": "The Enricher who makes wealthy."},
  {"order": 90, "ar": "الْمَانِعُ", "tr": "El-Mâni'", "en": "The Withholder", "meaning_tr": "Dilediğine vermeyerek koruyan.", "meaning_en": "The Withholder who protects by denying."},
  {"order": 91, "ar": "الضَّارُّ", "tr": "Ed-Dârr", "en": "The Distresser", "meaning_tr": "Dilediğine zarar veren.", "meaning_en": "The Distresser when He wills."},
  {"order": 92, "ar": "النَّافِعُ", "tr": "En-Nâfi'", "en": "The Benefiter", "meaning_tr": "Dilediğine fayda veren.", "meaning_en": "The Benefiter when He wills."},
  {"order": 93, "ar": "النُّورُ", "tr": "En-Nûr", "en": "The Light", "meaning_tr": "Göklerin ve yerin nuru.", "meaning_en": "The Light of the heavens and earth."},
  {"order": 94, "ar": "الْهَادِي", "tr": "El-Hâdî", "en": "The Guide", "meaning_tr": "Doğru yola ileten.", "meaning_en": "The Guide to the straight path."},
  {"order": 95, "ar": "الْبَدِيعُ", "tr": "El-Bedî'", "en": "The Originator", "meaning_tr": "Örneksiz ve eşsiz yaratan.", "meaning_en": "The Originator without precedent."},
  {"order": 96, "ar": "الْبَاقِي", "tr": "El-Bâkî", "en": "The Everlasting", "meaning_tr": "Varlığı sürekli olan.", "meaning_en": "The Everlasting without end."},
  {"order": 97, "ar": "الْوَارِثُ", "tr": "El-Vâris", "en": "The Inheritor", "meaning_tr": "Her şey yok olduktan sonra kalan.", "meaning_en": "The Inheritor after all perish."},
  {"order": 98, "ar": "الرَّشِيدُ", "tr": "Er-Reşîd", "en": "The Guide to Right Path", "meaning_tr": "İşlerinde sapmaktan uzak, doğru yola ileten.", "meaning_en": "The Guide to the right path."},
  {"order": 99, "ar": "الصَّبُورُ", "tr": "Es-Sabûr", "en": "The Patient", "meaning_tr": "Cezalandırmada acele etmeyen.", "meaning_en": "The Patient, not hasty in punishment."}
]
